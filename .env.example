# Ejemplo de variables de entorno para Banco BanQuito
# Copia este archivo a .env y actualiza según tu entorno

# ===== DATABASE =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=banquito_db
DB_USER=banquito_user
DB_PASSWORD=banquito_password

# ===== CORE SERVICE =====
CORE_PORT=8080
CORE_LOG_LEVEL=INFO
CORE_DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
CORE_DATASOURCE_USERNAME=${DB_USER}
CORE_DATASOURCE_PASSWORD=${DB_PASSWORD}

# ===== SWITCH SERVICE =====
SWITCH_PORT=8081
SWITCH_LOG_LEVEL=INFO
SWITCH_DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
SWITCH_DATASOURCE_USERNAME=${DB_USER}
SWITCH_DATASOURCE_PASSWORD=${DB_PASSWORD}

# ===== GENERAL =====
ENVIRONMENT=development
TIMEZONE=America/Guayaquil
LANGUAGE=es_ES

# ===== OPTIONAL: REDIS (Para cache) =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== EMAIL / NOTIFICATIONS =====
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=banquito@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=notificaciones@banquito.ec

# ===== LOGGING =====
LOG_PATH=./logs
LOG_LEVEL=INFO

# ===== CORS / SECURITY =====
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8081
JWT_SECRET=your-secret-key-here-change-in-production
